{
	"manifest_version": 3,
	"name": "__MSG_name__",
	"description": "__MSG_description__",
	"default_locale": "en",
	"version": "0.1.0",
	"icons": {
		"16": "img/icon_16.png",
		"48": "img/icon_48.png",
		"128": "img/icon_128.png"
	},
	"permissions": [
		"storage",
		"identity",
		"activeTab",
		"notifications",
		"scripting"
	],
	"host_permissions": [
		"https://coxauto.service-now.com/time*"
	],
	"action": {
		"default_icon": {
			"16": "img/icon_16.png",
			"48": "img/icon_48.png",
			"128": "img/icon_128.png"
		},
		"default_popup": "popup.html"
	},
	"content_scripts": [
		{
			"matches": ["https://coxauto.service-now.com/time*"],
			"js": ["js/content.js"],
			"run_at": "document_idle"
		}
	],
	"background": {
		"service_worker": "js/background.js",
		"type": "module"
	},
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self';"
	},
	"options_page": "options.html",
	"oauth2": {
		"client_id": "384905528545-5nupa2vochv26iqtfiokpj2c3s3lvolc.apps.googleusercontent.com",
		"scopes": ["https://www.googleapis.com/auth/drive.file"]
	},
	"externally_connectable": {
		"matches": ["https://nick-sorogovets.github.io/snow_time_extension/*"]
	}
}
