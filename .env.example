# Production Chrome Extension OAuth client ID (Google Cloud Console).
# Used only by `npm run build` to replace oauth2.client_id in build/manifest.json.
# Copy this file to `.env` and set your prod client id.
PROD_OAUTH_CLIENT_ID=

# Optional: base64 manifest `key` for stable Extension ID (same as Chrome Web Store).
# Save to `.keys/manifest-key.txt` or set here. See Deploy.md §8.
# MANIFEST_KEY=
