{
  "name": "snow-screenshot-extension",
  "version": "0.1.1",
  "description": "Take screenshot from SNOW page and upload to Google Drive.",
  "main": "src/js/popup.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "i18n": "node scripts/build-i18n.js",
    "clean": "rimraf build dist",
    "build": "npm run i18n && npm run clean && webpack --mode production && node scripts/zip-dist.js",
    "build:dev": "npm run i18n && rimraf build && webpack --mode development",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nick-sorogovets/snow_time_extension.git"
  },
  "keywords": [
    "snow",
    "screenshot",
    "google-drive",
    "chrome-extension"
  ],
  "author": "Nick Sorogovets",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nick-sorogovets/snow_time_extension/issues"
  },
  "homepage": "https://github.com/nick-sorogovets/snow_time_extension#readme",
  "devDependencies": {
    "archiver": "^7.0.1",
    "clean-css": "^5.3.3",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv": "^16.5.0",
    "html-minifier-terser": "^7.2.0",
    "rimraf": "^6.0.1",
    "terser-webpack-plugin": "^5.3.14",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  }
}
